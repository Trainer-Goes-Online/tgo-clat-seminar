# ============================================================
# CLAT Possible · Razorpay credentials — copy to .env.local and fill in.
# ============================================================
# Public Key ID (safe to expose; Razorpay's checkout modal needs it client-side).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Secret — NEVER expose. Used server-side to create orders + verify the HMAC signature.
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Seat price in paise. ₹49 = 4900. Single source of truth (server owns the amount).
RAZORPAY_AMOUNT_PAISE=4900
RAZORPAY_CURRENCY=INR
