# ============================================================
# CLAT Possible · FREE in-person CLAT seminar funnel — env template.
# Copy this file to .env.local for local dev (.env.local is gitignored).
# Set the SAME keys in Vercel for production. Restart `npm run dev` after edits.
# ============================================================

# ---- WhatsApp community invite (shown on the /confirmation page) ----
# Safe to expose (NEXT_PUBLIC_); it is just the public group invite link.
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/xxxxxxxx

# ---- Site origin (no trailing slash needed; used as event_source_url fallback) ----
NEXT_PUBLIC_SITE_URL=https://summit.clatpossible.com

# ---- Meta Pixel + Conversions API ----
# Pixel/Dataset ID — same value client + server (not a secret).
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=
# CAPI access token — server-only secret. NEVER prefix with NEXT_PUBLIC_.
META_CAPI_ACCESS_TOKEN=
# Graph API version (optional; defaults to v25.0 in code).
META_GRAPH_API_VERSION=v25.0
# Test Events code — paste a REAL code from Events Manager > Test Events while
# validating, then LEAVE BLANK in production (a value sends events to the test
# bucket only, so they won't count as real conversions).
META_TEST_EVENT_CODE=

# ---- Free-registration events (fired by /api/free-register) ----
# Standard Meta event — must be the exact name "CompleteRegistration" (no space)
# for Meta to treat it as a standard event. Set to "none" to fire custom-only.
FREE_STANDARD_EVENT=CompleteRegistration
FREE_CUSTOM_EVENT=FreeWebinarRegistration

# ---- Pabbly Connect webhook (writes the lead row into the Google Sheet CRM) ----
PABBLY_WEBHOOK_URL=

# ============================================================
# VIP upsell (One-Time Offer → Razorpay checkout → /thank-you-vip)
# Standalone flow, not yet linked from the funnel. Set these to enable it.
# ============================================================
# Price SHOWN to the user AND charged (in whole rupees). Public, not a secret.
# Changing this updates the offer page, checkout, CTA labels AND the charged amount.
NEXT_PUBLIC_VIP_PRICE_RUPEES=99
# Optional "was" price for the strike-through anchor on the offer page.
NEXT_PUBLIC_VIP_COMPARE_RUPEES=499
# VIP-only WhatsApp community (shown on /thank-you-vip; separate from the free group).
NEXT_PUBLIC_VIP_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/CcAHgXpYEC1A3um7OxFzE0
# ---- Razorpay API keys (from Razorpay Dashboard → Settings → API Keys) ----
# key_id is public-ish; key_secret is a SERVER-ONLY secret. Never prefix secret
# with NEXT_PUBLIC_. The order route returns key_id to the browser for checkout.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# ---- Pabbly Connect webhook for VIP purchases (separate row/flow from the free
# lead). Fires server-side ONLY after a verified successful payment. ----
PABBLY_VIP_WEBHOOK_URL=

# VIP purchase custom Meta CAPI event (server-side, after Razorpay verify).
# NO standard event is fired for VIP — only this custom event.
VIP_CUSTOM_EVENT=vip_sale
